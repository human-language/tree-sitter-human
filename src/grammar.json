{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "hmn",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_toplevel"
      }
    },
    "_toplevel": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "import_statement"
        },
        {
          "type": "SYMBOL",
          "name": "agent_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "system_directive"
        },
        {
          "type": "SYMBOL",
          "name": "constraints_block"
        },
        {
          "type": "SYMBOL",
          "name": "flow_block"
        },
        {
          "type": "SYMBOL",
          "name": "test_block"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "import_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "IMPORT"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "path"
            },
            {
              "type": "SYMBOL",
              "name": "package"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "agent_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "AGENT"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "agent_body"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "agent_body": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_agent_member"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "_agent_member": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "system_directive"
        },
        {
          "type": "SYMBOL",
          "name": "property"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "system_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "SYSTEM"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "path"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "property": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "_value"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "boolean"
        },
        {
          "type": "SYMBOL",
          "name": "path"
        }
      ]
    },
    "constraints_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "CONSTRAINTS"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "constraint"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "constraint": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "constraint_level"
        },
        {
          "type": "SYMBOL",
          "name": "constraint_text"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "constraint_level": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "NEVER"
        },
        {
          "type": "STRING",
          "value": "MUST"
        },
        {
          "type": "STRING",
          "value": "SHOULD"
        },
        {
          "type": "STRING",
          "value": "AVOID"
        },
        {
          "type": "STRING",
          "value": "MAY"
        }
      ]
    },
    "constraint_text": {
      "type": "PATTERN",
      "value": "[^\\n\\r]+"
    },
    "flow_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "FLOW"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "flow_step"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "flow_step": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "step_text"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "step_text": {
      "type": "PATTERN",
      "value": "[^\\n\\r]+"
    },
    "test_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "TEST"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_test_entry"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "_test_entry": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "test_input"
        },
        {
          "type": "SYMBOL",
          "name": "test_expect"
        }
      ]
    },
    "test_input": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "INPUT"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "test_expect": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "EXPECT"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "NOT"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "CONTAINS"
            },
            {
              "type": "STRING",
              "value": "MATCHES"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "path": {
      "type": "PATTERN",
      "value": "\\.\\.?\\/[^\\n\\r \\t]*"
    },
    "package": {
      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9._\\/-]*"
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "string_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "string_content": {
      "type": "PATTERN",
      "value": "([^\"\\\\]|\\\\[\"\\\\])+"
    },
    "number": {
      "type": "PATTERN",
      "value": "[0-9]+(\\.[0-9]+)?"
    },
    "boolean": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "PATTERN",
            "value": "#"
          }
        },
        {
          "type": "PATTERN",
          "value": "[^\\n\\r]*"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    },
    {
      "type": "SYMBOL",
      "name": "_newline"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}